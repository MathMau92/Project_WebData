@prefix ent: <http://videogamekg.org/entity/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sch: <https://schema.org/> .
@prefix vg: <http://videogamekg.org/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ent:7_Mages a vg:Game ;
    rdfs:label "7 Mages"@en ;
    vg:availableOn ent:Android,
        ent:Linux,
        ent:PC,
        ent:i_OS,
        ent:mac_OS ;
    vg:developedBy ent:Napoleon_Games ;
    vg:hasGenre ent:Adventure,
        ent:RPG ;
    vg:publishedBy ent:Napoleon_Games ;
    vg:rating "2.0"^^xsd:float ;
    vg:rawgId 2120 ;
    vg:releaseYear 2016 ;
    vg:website "http://www.7mages.net/"^^xsd:anyURI .

ent:Arma_3 a vg:Game ;
    rdfs:label "Arma 3"@en ;
    vg:availableOn ent:PC ;
    vg:developedBy ent:Bohemia_Interactive ;
    vg:hasGenre ent:Action,
        ent:Shooter,
        ent:Simulation,
        ent:Strategy ;
    vg:metacritic 74 ;
    vg:publishedBy ent:Bohemia_Interactive ;
    vg:rating "3.84"^^xsd:float ;
    vg:rawgId 9997 ;
    vg:releaseYear 2013 ;
    vg:website "http://www.arma3.com"^^xsd:anyURI .

ent:Saku_Saku_Love_Blooms_with_the_Cherry_Blossoms a vg:Game ;
    rdfs:label "Saku Saku: Love Blooms with the Cherry Blossoms"@en ;
    vg:availableOn ent:PC ;
    vg:developedBy ent:PALETTE ;
    vg:hasGenre ent:Casual ;
    vg:publishedBy ent:Sekai_Project ;
    vg:rawgId 47124 ;
    vg:releaseYear 2017 .

vg:availableOn a owl:ObjectProperty ;
    rdfs:label "available on"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Platform .

vg:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:range xsd:string .

vg:developedBy a owl:ObjectProperty ;
    rdfs:label "developed by"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Studio ;
    owl:equivalentProperty sch:author .

vg:hasGenre a owl:ObjectProperty ;
    rdfs:label "has genre"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Genre ;
    owl:equivalentProperty sch:genre .

vg:metacritic a owl:DatatypeProperty ;
    rdfs:label "metacritic score"@en ;
    rdfs:range xsd:integer .

vg:publishedBy a owl:ObjectProperty ;
    rdfs:label "published by"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Publisher .

vg:rating a owl:DatatypeProperty ;
    rdfs:label "average rating"@en ;
    rdfs:range xsd:float .

vg:rawgId a owl:DatatypeProperty ;
    rdfs:label "RAWG identifier"@en ;
    rdfs:range xsd:integer .

vg:releaseYear a owl:DatatypeProperty ;
    rdfs:label "release year"@en ;
    rdfs:range xsd:integer .

vg:sameStudioAs a owl:SymmetricProperty ;
    rdfs:label "developed by same studio"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Game .

vg:similarTo a owl:SymmetricProperty ;
    rdfs:label "similar game"@en ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Game .

vg:website a owl:DatatypeProperty ;
    rdfs:label "official website"@en ;
    rdfs:range xsd:anyURI .

ent:Action a vg:Genre ;
    rdfs:label "Action"@en .

ent:Adventure a vg:Genre ;
    rdfs:label "Adventure"@en .

ent:Android a vg:Platform ;
    rdfs:label "Android"@en .

ent:Casual a vg:Genre ;
    rdfs:label "Casual"@en .

ent:Linux a vg:Platform ;
    rdfs:label "Linux"@en .

ent:PALETTE a vg:Studio ;
    rdfs:label "PALETTE"@en .

ent:RPG a vg:Genre ;
    rdfs:label "RPG"@en .

ent:Sekai_Project a vg:Publisher ;
    rdfs:label "Sekai Project"@en .

ent:Shooter a vg:Genre ;
    rdfs:label "Shooter"@en .

ent:Simulation a vg:Genre ;
    rdfs:label "Simulation"@en .

ent:Strategy a vg:Genre ;
    rdfs:label "Strategy"@en .

ent:i_OS a vg:Platform ;
    rdfs:label "iOS"@en .

ent:mac_OS a vg:Platform ;
    rdfs:label "macOS"@en .

ent:Bohemia_Interactive a vg:Publisher,
        vg:Studio ;
    rdfs:label "Bohemia Interactive"@en .

ent:Napoleon_Games a vg:Publisher,
        vg:Studio ;
    rdfs:label "Napoleon Games"@en .

ent:PC a vg:Platform ;
    rdfs:label "PC"@en .

vg:Publisher a owl:Class ;
    rdfs:label "Game Publisher"@en .

vg:Studio a owl:Class ;
    rdfs:label "Game Studio"@en .

vg:Platform a owl:Class ;
    rdfs:label "Gaming Platform"@en .

vg:Genre a owl:Class ;
    rdfs:label "Game Genre"@en .

vg:Game a owl:Class ;
    rdfs:label "Video Game"@en ;
    owl:equivalentClass sch:VideoGame .

